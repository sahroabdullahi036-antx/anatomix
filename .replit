modules = ["nodejs-20", "web", "python-3.11"]
[agent]
expertMode = true
stack = "FULLSTACK_JS"
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]
publicDir = "dist/public"

[userenv]

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "anatomix-c3885.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "anatomix-c3885"
VITE_FIREBASE_STORAGE_BUCKET = "anatomix-c3885.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "31474037206"
VITE_FIREBASE_APP_ID = "1:31474037206:web:db3cf1ac01a67d4105b477"
